{
  "name": "frontend",
  "version": "19.2.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production && npm run sbom",
    "sbom": "cyclonedx-esbuild --output-reproducible --output-file dist/bom/bom.json dist/frontend/stats.json",
    "bundle-visualizer": "npx esbuild-visualizer --metadata dist/frontend/stats.json --filename dist/frontend/bundle-report.html",
    "test": "ng test",
    "lint": "ng lint",
    "lint:scss": "npx stylelint \"**/*.scss\"",
    "lint:fix": "ng lint --fix && npx stylelint \"**/*.scss\" --fix"
  },
  "private": true,
